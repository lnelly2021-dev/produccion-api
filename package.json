{
  "name": "api-pos",
  "version": "1.0.0",
  "description": "API base reutilizable en TypeScript (Express + Mongoose + Socket.IO).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "predev": "npx kill-port 5000 5001",
    "dev": "nodemon --exec npx ts-node index.ts",
    "start": "npm run build && node --max-old-space-size=4096 dist/index.js"
  },
  "keywords": [
    "typescript",
    "express",
    "mongoose",
    "template"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/helmet": "^0.0.48",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
